━━━━ SELECTOR PRIORITY (always use in this order) ━━━━━━━━━━━━━━━━━━━━━━━━━━━

  1. page.getByRole('button', { name: 'Submit' })    ← best: accessible role
  2. page.getByLabel('Email address')                ← for labeled form fields
  3. page.getByPlaceholder('Enter your email')       ← for unlabeled inputs
  4. page.getByTestId('submit-button')               ← for custom elements
  5. page.getByText('Exact visible text')            ← last resort

